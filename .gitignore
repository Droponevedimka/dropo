# Build artifacts - runtime files (template.json is embedded and copied at runtime)
app/build/bin/*.exe
app/build/bin/*.dll
app/build/bin/config.json
app/build/bin/user_settings.json
app/build/bin/user_settings_*.json
app/build/bin/cache.db
app/build/bin/vpn.log
app/build/bin/sing-box.exe
app/build/bin/template.json
app/build/bin/bin/
app/build/bin/profiles.json
app/build/bin/app_config.json
app/build/bin/resources/

# Release builds
release/

# Bundled dependencies are NOT stored in git: build.ps1 downloads them into this
# local cache at build time, and they ship to users as a separate release asset
# (dependencies-<depsVersion>.zip) downloaded on first run. See docs/UPDATE.md.
dependencies/

# Go
*.so
*.dylib
*.test
*.out
go.work
go.work.sum

# Node.js
app/frontend/node_modules/
app/frontend/dist/
app/frontend/playwright-report/
app/frontend/test-results/
app/frontend/package.json.md5
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Wails
app/frontend/src/wailsjs/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Environment
.env
.env.local
.env.*.local
*.local

# Secrets (никогда не коммитить!)
**/private_key*
**/secret*
**/*credentials*
**/*password*
# Subscription / proxy material accidentally dumped to disk
**/sub.txt
**/subscription*.txt
**/*.subscription
# Client DPI fingerprints captured at runtime (resources copy; lab keeps its own DB)
app/resources/fingerprints/
resources/fingerprints/

# Build output left next to sources
app/*.exe
app/dropo.exe

# Production release publisher — owner-only, must NOT be public
release.ps1
release.local.ps1

# Test-lab generated artifacts (regenerated by tools/build_profile.py)
testlab/profiles/censor-profile.json

